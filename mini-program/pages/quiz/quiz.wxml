<!-- pages/quiz/quiz.wxml -->
<view class="container">
  <!-- 刷题模式切换 -->
  <view class="quiz-mode-tabs">
    <view class="quiz-mode {{quizMode === 'choice' ? 'active' : ''}}" bindtap="switchQuizMode" data-mode="choice">选择题</view>
    <view class="quiz-mode {{quizMode === 'fillblank' ? 'active' : ''}}" bindtap="switchQuizMode" data-mode="fillblank">填空题</view>
    <view class="quiz-mode {{quizMode === 'calc' ? 'active' : ''}}" bindtap="switchQuizMode" data-mode="calc">计算题</view>
  </view>

  <!-- 选择题内容 -->
  <view wx:if="{{quizMode === 'choice'}}">
    <!-- 分类标签 -->
    <view class="category-tabs" wx:if="{{!isAnswering}}">
      <view class="tab {{activeCategory === 'all' ? 'active' : ''}}" bindtap="switchCategory" data-cat="all">全部</view>
      <view class="tab {{activeCategory === 'geo' ? 'active' : ''}}" bindtap="switchCategory" data-cat="geo">几何光学</view>
      <view class="tab {{activeCategory === 'phy' ? 'active' : ''}}" bindtap="switchCategory" data-cat="phy">物理光学</view>
    </view>

    <!-- 难度筛选 -->
    <view class="difficulty-filter" wx:if="{{!isAnswering}}">
      <view class="filter-label">难度:</view>
      <view class="filter-options">
        <view class="filter-opt {{activeDifficulty === 'all' ? 'active' : ''}}" bindtap="switchDifficulty" data-diff="all">全部</view>
        <view class="filter-opt {{activeDifficulty === 'easy' ? 'active' : ''}}" bindtap="switchDifficulty" data-diff="easy">简单</view>
        <view class="filter-opt {{activeDifficulty === 'medium' ? 'active' : ''}}" bindtap="switchDifficulty" data-diff="medium">中等</view>
        <view class="filter-opt {{activeDifficulty === 'hard' ? 'active' : ''}}" bindtap="switchDifficulty" data-diff="hard">困难</view>
      </view>
    </view>

    <!-- 题目列表 -->
    <view class="question-list" wx:if="{{!isAnswering}}">
      <block wx:for="{{filteredQuestions}}" wx:key="id">
        <view class="question-card card" bindtap="startAnswer" data-index="{{index}}">
          <view class="question-header">
            <view class="question-tags">
              <text class="tag {{item.chapter === '几何光学' ? 'tag-geo' : 'tag-phy'}}">{{item.chapter}}</text>
              <text class="tag tag-{{item.difficulty}}">{{item.difficulty === 'easy' ? '简单' : item.difficulty === 'medium' ? '中等' : '困难'}}</text>
            </view>
            <view class="question-topic">{{item.topic}}</view>
          </view>
          <rich-text class="question-text" nodes="{{item.parsedQuestion}}"></rich-text>
          <view class="question-footer">
            <text class="text-sm">点击查看解析</text>
            <text class="arrow">›</text>
          </view>
        </view>
      </block>
    </view>

    <!-- 答题界面 -->
    <view class="answer-panel" wx:if="{{isAnswering}}">
      <view class="answer-header">
        <view class="back-btn" bindtap="exitAnswer">← 返回</view>
        <view class="answer-progress">第 {{currentIndex + 1}} / {{filteredQuestions.length}} 题</view>
      </view>

      <view class="answer-card card">
        <view class="question-tags">
          <text class="tag {{currentQuestion.chapter === '几何光学' ? 'tag-geo' : 'tag-phy'}}">{{currentQuestion.chapter}}</text>
          <text class="tag tag-{{currentQuestion.difficulty}}">{{currentQuestion.difficulty === 'easy' ? '简单' : currentQuestion.difficulty === 'medium' ? '中等' : '困难'}}</text>
        </view>
        <rich-text class="answer-question" nodes="{{currentQuestion.parsedQuestion}}"></rich-text>
        
        <view class="options-list">
          <block wx:for="{{currentQuestion.options}}" wx:for-index="optIdx" wx:key="*this">
            <view class="option {{answered ? (optIdx === correctIndex ? 'correct' : (optIdx === selectedIndex ? 'wrong' : '')) : ''}} {{selectedIndex === optIdx ? 'selected' : ''}}" 
                  bindtap="selectOption" 
                  data-index="{{optIdx}}"
                  hidden="{{answered && optIdx !== selectedIndex && optIdx !== correctIndex}}">
              <view class="option-letter">{{['A','B','C','D'][optIdx]}}</view>
              <rich-text class="option-text" nodes="{{currentQuestion.parsedOptions[optIdx]}}"></rich-text>
            </view>
          </block>
        </view>
      </view>

      <!-- 解析面板 -->
      <view class="explanation-panel card" wx:if="{{answered}}">
        <view class="explanation-title {{isCorrect ? 'correct-title' : 'wrong-title'}}">
          {{isCorrect ? '✅ 回答正确' : '❌ 回答错误'}}
        </view>
        <view class="explanation-content">
          <view class="title-md">📖 解析</view>
          <rich-text nodes="{{currentQuestion.parsedExplanation}}"></rich-text>
        </view>
        <view class="explanation-answer">
          <text class="title-md">✅ 正确答案：{{currentQuestion.answer}}</text>
        </view>
      </view>

      <!-- 答错记忆卡 -->
      <view class="wrong-hint-card card" wx:if="{{answered && !isCorrect}}">
        <view class="hint-header">
          <text class="hint-icon">💡</text>
          <text class="hint-title">辅助记忆卡</text>
        </view>
        <view class="hint-type">{{currentQuestion.wrong_hint.type}}</view>
        <view class="hint-message"><rich-text nodes="{{currentQuestion.parsedHintMessage}}"></rich-text></view>
        <view class="hint-actions">
          <button class="btn-outline" bindtap="goToRelated">查看相关知识点</button>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="answer-actions" wx:if="{{answered}}">
        <button class="btn-outline" bindtap="collectQuestion">
          {{isCollected ? '❤️ 已收藏' : '🤍 收藏'}}
        </button>
        <button class="btn-primary" bindtap="nextQuestion">{{currentIndex < filteredQuestions.length - 1 ? '下一题' : '完成刷题'}}</button>
      </view>
    </view>
  </view>

  <!-- 填空题入口 -->
  <view class="calc-entry" wx:if="{{quizMode === 'fillblank' && !isAnswering}}">
    <view class="title-md">📝 核心概念填空</view>
    <view class="text-sm" style="margin-bottom: 24rpx;">从知识库中抽取136道核心概念填空题，考察关键术语记忆</view>
    <view class="calc-entry-card card" bindtap="goToFillblank">
      <view class="calc-entry-icon">📝</view>
      <view class="calc-entry-info">
        <view class="calc-entry-title">进入填空题训练</view>
        <view class="calc-entry-desc">覆盖几何光学和物理光学核心概念</view>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 计算题入口 -->
  <view class="calc-entry" wx:if="{{quizMode === 'calc' && !isAnswering}}">
    <view class="title-md">📐 计算题步骤填空</view>
    <view class="text-sm" style="margin-bottom: 24rpx;">每道题拆分为3-4个步骤，逐步验证，答错即时诊断</view>
    <view class="calc-entry-card card" bindtap="goToCalculation">
      <view class="calc-entry-icon">📐</view>
      <view class="calc-entry-info">
        <view class="calc-entry-title">进入计算题训练</view>
        <view class="calc-entry-desc">10道经典计算题，涵盖几何光学和物理光学</view>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
