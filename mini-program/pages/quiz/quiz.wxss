/* pages/quiz/quiz.wxss */
/* 模式切换 */
.quiz-mode-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.quiz-mode {
  flex: 1;
  padding: 16rpx 24rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: var(--text-light);
  background: var(--card-bg);
  border: 2rpx solid var(--border);
  text-align: center;
}

.quiz-mode.active {
  background: var(--primary);
  color: white;
  border-color: var(--primary);
}

/* 计算题入口 */
.calc-entry {
  animation: fadeIn 0.3s ease-out;
}

.calc-entry-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  margin-top: 20rpx;
}

.calc-entry-icon {
  font-size: 60rpx;
  margin-right: 24rpx;
}

.calc-entry-info {
  flex: 1;
}

.calc-entry-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8rpx;
}

.calc-entry-desc {
  font-size: 24rpx;
  color: var(--text-light);
}

.category-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.tab {
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: var(--text-light);
  background: var(--card-bg);
  border: 2rpx solid var(--border);
}

.tab.active {
  background: var(--primary);
  color: white;
  border-color: var(--primary);
}

.difficulty-filter {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.filter-label {
  font-size: 26rpx;
  color: var(--text-light);
  white-space: nowrap;
}

.filter-options {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.filter-opt {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--text-light);
  background: var(--card-bg);
  border: 2rpx solid var(--border);
}

.filter-opt.active {
  background: var(--secondary);
  color: white;
  border-color: var(--secondary);
}

/* 题目列表 */
.question-card {
  margin-bottom: 20rpx;
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.question-tags {
  display: flex;
  gap: 10rpx;
}

.question-topic {
  font-size: 22rpx;
  color: var(--text-light);
}

.question-text {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.question-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 2rpx solid var(--border);
}

/* 答题界面 */
/* 答题界面头部 */
.answer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.back-btn {
  font-size: 28rpx;
  color: var(--primary);
  padding: 10rpx 20rpx;
  background: var(--card-bg);
  border-radius: 30rpx;
  border: 2rpx solid var(--primary);
}

.back-btn:active {
  opacity: 0.8;
  background: var(--primary);
  color: white;
}

.answer-progress {
  font-size: 26rpx;
  color: var(--text-light);
}

.answer-card {
  margin-bottom: 20rpx;
}

.answer-question {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text);
  line-height: 1.6;
  margin: 24rpx 0;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: var(--bg);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.option.selected {
  border-color: var(--primary);
  background: #e8f0fe;
}

.option.correct {
  border-color: var(--success);
  background: #e8f5e9;
}

.option.wrong {
  border-color: var(--danger);
  background: #ffebee;
}

.option-letter {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--primary);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option.correct .option-letter {
  background: var(--success);
}

.option.wrong .option-letter {
  background: var(--danger);
}

.option-text {
  font-size: 28rpx;
  color: var(--text);
  flex: 1;
}

/* 解析面板 */
.explanation-panel {
  margin-bottom: 20rpx;
  animation: fadeIn 0.3s ease-out;
}

.explanation-title {
  font-size: 32rpx;
  font-weight: 600;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
  border-bottom: 2rpx solid var(--border);
}

.correct-title {
  color: var(--success);
}

.wrong-title {
  color: var(--danger);
}

.explanation-content {
  margin-bottom: 20rpx;
}

.explanation-content text {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.8;
  display: block;
  margin-top: 12rpx;
}

.explanation-answer {
  padding: 16rpx 0;
  border-top: 2rpx solid var(--border);
}

/* 答错记忆卡 */
.wrong-hint-card {
  background: #fff8e1;
  border-left: 6rpx solid var(--secondary);
  animation: fadeIn 0.3s ease-out;
}

.hint-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.hint-icon {
  font-size: 40rpx;
}

.hint-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.hint-type {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: var(--secondary);
  color: white;
  margin-bottom: 16rpx;
}

.hint-message {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.hint-actions {
  display: flex;
  justify-content: flex-end;
}

/* 智能推荐模式 */
.smart-mode-entry {
  margin-bottom: 24rpx;
}

.smart-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  border: 2rpx solid var(--primary);
  border-radius: 16rpx;
}

.smart-card:active {
  background: #e8f0fe;
}

.smart-icon {
  font-size: 60rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.smart-info {
  flex: 1;
}

.smart-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8rpx;
}

.smart-desc {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 薄弱点报告 */
.weak-report {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: var(--card-bg);
  border-radius: 16rpx;
  border: 2rpx solid var(--border);
}

.report-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--border);
}

.report-stats {
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  background: var(--bg);
  border-radius: 12rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-light);
}

.report-weak {
  margin-bottom: 16rpx;
}

.report-subtitle {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 12rpx;
}

.weak-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.weak-chip {
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  background: #ffebee;
  color: var(--danger);
  border: 2rpx solid #ffcdd2;
}

.error-chip {
  background: #fff8e1;
  color: #f57c00;
  border-color: #ffe082;
}

.unstarted-chip {
  background: #e8f5e9;
  color: var(--success);
  border-color: #c8e6c9;
}

.report-empty {
  text-align: center;
  padding: 20rpx 0;
  color: var(--text-light);
  font-size: 26rpx;
}

/* 智能模式答题提示 */
.smart-banner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #e8f0fe;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid var(--primary);
}

.smart-banner-text {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

.smart-banner-exit {
  font-size: 24rpx;
  color: var(--danger);
  padding: 6rpx 16rpx;
  border: 2rpx solid var(--danger);
  border-radius: 20rpx;
}

.smart-banner-exit:active {
  background: #ffebee;
}
