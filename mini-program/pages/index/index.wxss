/* pages/index/index.wxss */
.search-bar {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
}

.search-btn {
  padding: 8rpx 16rpx;
  font-size: 32rpx;
}

/* 快捷入口 */
.quick-grid {
  display: flex;
  justify-content: space-around;
  margin-top: 20rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  background: var(--bg);
}

.quick-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.quick-text {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 思维导图 */
.mindmap-tree {
  margin-top: 20rpx;
}

.branch {
  margin-bottom: 16rpx;
}

.branch-header {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.branch-icon {
  font-size: 24rpx;
  color: var(--primary);
  margin-right: 12rpx;
  width: 32rpx;
  text-align: center;
}

.branch-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary);
  flex: 1;
}

.branch-count {
  font-size: 24rpx;
  color: var(--text-light);
}

.section {
  padding-left: 32rpx;
  border-left: 4rpx solid var(--border);
  margin-left: 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.section-icon {
  font-size: 20rpx;
  color: var(--text-light);
  margin-right: 12rpx;
  width: 28rpx;
  text-align: center;
}

.section-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text);
}

.topic-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0 12rpx 32rpx;
}

.topic-icon {
  font-size: 18rpx;
  color: var(--text-light);
  margin-right: 10rpx;
  width: 24rpx;
  text-align: center;
}

.topic-name {
  font-size: 26rpx;
  color: var(--text-light);
}

.topic-children {
  padding-left: 56rpx;
}

.leaf-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
  border-radius: 12rpx;
  background: var(--bg);
}

.leaf-item.formula {
  background: #e8f0fe;
}

.leaf-item.knowledge {
  background: #fff8e1;
}

.leaf-tag {
  font-size: 28rpx;
  margin-right: 16rpx;
  width: 40rpx;
  text-align: center;
}

.formula-tag {
  color: var(--primary);
}

.knowledge-tag {
  color: var(--secondary);
}

.leaf-name {
  font-size: 26rpx;
  color: var(--text);
  flex: 1;
}

/* 搜索弹窗 */
.search-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.search-panel {
  width: 100%;
  height: 70vh;
  background: var(--card-bg);
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 30rpx;
  animation: slideUp 0.3s ease-out;
}

.search-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.close-btn {
  font-size: 36rpx;
  color: var(--text-light);
  padding: 10rpx;
}

.search-result {
  height: calc(70vh - 120rpx);
}

.search-item {
  padding: 24rpx;
  border-bottom: 2rpx solid var(--border);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  background: var(--bg);
}

.search-item.formula {
  background: #e8f0fe;
}

.search-item.knowledge {
  background: #fff8e1;
}

.type-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
  display: inline-block;
}

.type-badge.formula {
  background: var(--primary);
  color: white;
}

.type-badge.knowledge {
  background: var(--secondary);
  color: white;
}

.search-item-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 8rpx;
}

.search-item-latex {
  font-size: 28rpx;
  color: var(--primary-dark);
  font-family: 'Courier New', monospace;
}

.empty-state {
  text-align: center;
  padding: 60rpx;
  color: var(--text-light);
  font-size: 28rpx;
}
