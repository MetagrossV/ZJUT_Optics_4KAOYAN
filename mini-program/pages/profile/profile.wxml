<!-- pages/profile/profile.wxml -->
<view class="container">
  <view class="profile-header">
    <view class="avatar">
      <text>🔬</text>
    </view>
    <view class="profile-info">
      <view class="profile-name">浙工大光学考研</view>
      <view class="profile-desc">刷题小程序 v1.0</view>
    </view>
  </view>

  <view class="settings-list">
    <view class="settings-card card">
      <view class="settings-title">📊 学习数据</view>
      <view class="settings-item">
        <text>总答题数</text>
        <text class="settings-value">{{stats.totalAnswered}}</text>
      </view>
      <view class="settings-item">
        <text>正确率</text>
        <text class="settings-value">{{accuracy}}%</text>
      </view>
      <view class="settings-item">
        <text>收藏公式</text>
        <text class="settings-value">{{stats.favorites.formulas.length}}</text>
      </view>
      <view class="settings-item">
        <text>收藏题目</text>
        <text class="settings-value">{{stats.favorites.questions.length}}</text>
      </view>
    </view>

    <view class="settings-card card">
      <view class="settings-title">⚙️ 设置</view>
      <view class="settings-item" bindtap="clearCache">
        <text>清除缓存数据</text>
        <text class="arrow">›</text>
      </view>
      <view class="settings-item">
        <text>关于我们</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>
</view>
