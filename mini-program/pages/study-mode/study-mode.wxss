/* pages/study-mode/study-mode.wxss */
.title-lg {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

.chapter-list {
  margin-top: 24rpx;
}

.chapter-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  margin-bottom: 20rpx;
  background: var(--card-bg);
  border-radius: 16rpx;
  border: 2rpx solid var(--border);
}

.chapter-card:active {
  background: var(--bg);
}

.chapter-icon {
  font-size: 60rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.chapter-info {
  flex: 1;
}

.chapter-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8rpx;
}

.chapter-desc {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 难度筛选 */
.difficulty-filter {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.filter-label {
  font-size: 26rpx;
  color: var(--text-light);
  white-space: nowrap;
}

.filter-options {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.filter-opt {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--text-light);
  background: var(--card-bg);
  border: 2rpx solid var(--border);
}

.filter-opt.active {
  background: var(--secondary);
  color: white;
  border-color: var(--secondary);
}

/* 学习资料 */
.learn-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.back-btn {
  font-size: 28rpx;
  color: var(--primary);
  padding: 10rpx 20rpx;
  background: var(--card-bg);
  border-radius: 30rpx;
  border: 2rpx solid var(--primary);
}

.learn-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.learn-scroll {
  height: calc(100vh - 300rpx);
}

.material-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.material-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.material-type {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.material-type.formula {
  background: #e8f0fe;
  color: var(--primary);
}

.material-type.knowledge {
  background: #fff8e1;
  color: #f57c00;
}

.material-topic {
  font-size: 22rpx;
  color: var(--text-light);
}

.material-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

.material-content {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.8;
}

.learn-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 30rpx;
  background: var(--card-bg);
  border-top: 2rpx solid var(--border);
}

.learn-actions .btn-primary {
  width: 100%;
}

/* 答题界面 */
.quiz-progress {
  font-size: 26rpx;
  color: var(--text-light);
}

.answer-card {
  margin-bottom: 20rpx;
}

.answer-question {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text);
  line-height: 1.6;
  margin: 24rpx 0;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: var(--bg);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.option.selected {
  border-color: var(--primary);
  background: #e8f0fe;
}

.option.correct {
  border-color: var(--success);
  background: #e8f5e9;
}

.option.wrong {
  border-color: var(--danger);
  background: #ffebee;
}

.option-letter {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--primary);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option.correct .option-letter {
  background: var(--success);
}

.option.wrong .option-letter {
  background: var(--danger);
}

.option-text {
  font-size: 28rpx;
  color: var(--text);
  flex: 1;
}

/* 解析面板 */
.explanation-panel {
  margin-bottom: 20rpx;
  animation: fadeIn 0.3s ease-out;
}

.explanation-title {
  font-size: 32rpx;
  font-weight: 600;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
  border-bottom: 2rpx solid var(--border);
}

.correct-title {
  color: var(--success);
}

.wrong-title {
  color: var(--danger);
}

.explanation-content {
  margin-bottom: 20rpx;
}

.explanation-answer {
  padding: 16rpx 0;
  border-top: 2rpx solid var(--border);
}

.answer-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.answer-actions .btn-outline,
.answer-actions .btn-primary {
  flex: 1;
}
