/* pages/formula-detail/formula-detail.wxss */
.detail-card {
  animation: fadeIn 0.3s ease-out;
}

.detail-header {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.formula-box {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin: 24rpx 0;
  text-align: center;
  border-left: 6rpx solid var(--primary);
}

.formula-latex {
  font-size: 36rpx;
  color: var(--primary-dark);
  font-weight: 600;
  font-family: 'Courier New', monospace;
  line-height: 1.8;
}

.detail-section {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid var(--border);
}

.detail-text {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.8;
  display: block;
}

.variables-list {
  margin-top: 16rpx;
}

.variable-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: var(--bg);
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.variable-symbol {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary);
  margin-right: 20rpx;
  min-width: 60rpx;
  font-family: 'Courier New', monospace;
}

.variable-desc {
  font-size: 26rpx;
  color: var(--text-light);
  flex: 1;
}

.related-list {
  margin-top: 16rpx;
}

.related-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: var(--bg);
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.related-item text:first-child {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
}

.latex-mini {
  font-size: 24rpx;
  color: var(--primary);
  margin-right: 16rpx;
  font-family: 'Courier New', monospace;
}

.arrow {
  font-size: 32rpx;
  color: var(--text-light);
}

.action-bar {
  margin-top: 40rpx;
  display: flex;
  justify-content: center;
}

.action-bar .btn-outline {
  width: 100%;
  text-align: center;
}

.action-bar .btn-outline.favorited {
  border-color: var(--danger);
  color: var(--danger);
}

/* 高频公式 */
.highfreq-list {
  margin-top: 20rpx;
}

.formula-card {
  margin-bottom: 20rpx;
}

.formula-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 12rpx;
}

.formula-reason {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx dashed var(--border);
}

/* 易混淆对比 */
.confusion-list {
  margin-top: 20rpx;
}

.confusion-card {
  margin-bottom: 24rpx;
}

.confusion-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary);
  text-align: center;
  margin-bottom: 24rpx;
}

.confusion-vs {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.vs-left, .vs-right {
  flex: 1;
  background: var(--bg);
  border-radius: 12rpx;
  padding: 20rpx;
}

.vs-left {
  border-left: 4rpx solid var(--primary);
}

.vs-right {
  border-right: 4rpx solid var(--secondary);
}

.vs-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--danger);
  width: 60rpx;
}

.vs-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 12rpx;
}

.vs-content {
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.6;
}

.confusion-diff {
  background: #fff8e1;
  border-radius: 12rpx;
  padding: 20rpx;
}

.confusion-diff text {
  font-size: 26rpx;
  color: var(--text);
  line-height: 1.6;
  display: block;
  margin-top: 12rpx;
}
