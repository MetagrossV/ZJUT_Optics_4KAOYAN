/* pages/mistakes/mistakes.wxss */
.stats-overview {
  margin-bottom: 20rpx;
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
}

.stat-number {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 薄弱点 */
.weak-list {
  margin-top: 16rpx;
}

.weak-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.weak-info {
  flex: 1;
}

.weak-type {
  font-size: 26rpx;
  color: var(--text);
  margin-bottom: 8rpx;
}

.weak-bar {
  height: 12rpx;
  background: var(--border);
  border-radius: 6rpx;
  overflow: hidden;
}

.weak-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.weak-count {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--danger);
  margin-left: 20rpx;
  min-width: 80rpx;
  text-align: right;
}

/* 章节进度 */
.progress-list {
  margin-top: 16rpx;
}

.progress-item {
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.progress-chapter {
  font-size: 26rpx;
  color: var(--text);
}

.progress-rate {
  font-size: 24rpx;
  color: var(--text-light);
}

.progress-bar-bg {
  height: 12rpx;
  background: var(--border);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar-green {
  height: 100%;
  background: var(--success);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

/* 错题列表 */
.mistakes-section {
  margin-top: 20rpx;
}

.mistakes-list {
  margin-top: 16rpx;
}

.mistake-card {
  margin-bottom: 20rpx;
}

.mistake-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.mistake-tags {
  display: flex;
  gap: 10rpx;
}

.mistake-date {
  font-size: 22rpx;
  color: var(--text-light);
}

.mistake-question {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.mistake-answer {
  padding: 12rpx 16rpx;
  background: #e8f5e9;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.mistake-answer text {
  font-size: 26rpx;
  color: var(--success);
}

.mistake-actions {
  display: flex;
  gap: 16rpx;
}

.mistake-actions .btn-outline {
  flex: 1;
  font-size: 24rpx;
  padding: 14rpx 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-light);
}
