/** 绘图题页面样式 - 交互式光学编辑器 **/

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f5f6fa;
}

/* 题目区 */
.quiz-header {
  background: #ffffff;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #e9ecef;
}

.quiz-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}

.quiz-description {
  font-size: 26rpx;
  color: #495057;
  line-height: 1.5;
}

.quiz-progress {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.progress-text {
  font-size: 24rpx;
  color: #6c757d;
}

.score-badge {
  background: #4a69bd;
  color: #ffffff;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* Canvas 区域 */
.canvas-wrapper {
  margin: 20rpx 30rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  position: relative;
}

.drawing-canvas {
  display: block;
  width: 750rpx;
  height: 600rpx;
  background: #f8f9fa;
}

.placement-hint {
  position: absolute;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(74, 105, 189, 0.9);
  color: #ffffff;
  font-size: 26rpx;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  z-index: 10;
}

/* 工具箱 */
.toolbox {
  margin: 0 30rpx 20rpx;
  padding: 20rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.toolbox-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.toolbox-items {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.toolbox-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  transition: background 0.2s;
  border: 2rpx solid transparent;
}

.toolbox-item.active {
  background: #e7ecf8;
  border-color: #4a69bd;
}

.toolbox-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 10rpx;
}

.toolbox-name {
  font-size: 24rpx;
  color: #495057;
}

.toolbox-item.active .toolbox-name {
  color: #4a69bd;
  font-weight: 600;
}

/* 参数面板 */
.param-panel {
  margin: 0 30rpx 20rpx;
  padding: 20rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.param-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #e9ecef;
}

.param-panel-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.param-panel-delete {
  font-size: 24rpx;
  color: #ff6b6b;
  padding: 6rpx 16rpx;
}

.param-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.param-label {
  font-size: 26rpx;
  color: #495057;
  width: 120rpx;
  flex-shrink: 0;
}

.param-slider {
  flex: 1;
  margin-left: 16rpx;
}

/* 操作按钮 */
.action-bar {
  display: flex;
  justify-content: space-between;
  padding: 0 30rpx 20rpx;
}

.action-btn {
  flex: 1;
  margin: 0 8rpx;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
  border: none;
  line-height: 1.4;
}

.btn-primary {
  background: #4a69bd;
  color: #ffffff;
}

.btn-secondary {
  background: #e9ecef;
  color: #495057;
}

.btn-danger {
  background: #ff6b6b;
  color: #ffffff;
}

.btn-success {
  background: #2f9e44;
  color: #ffffff;
}

/* 验证结果 */
.result-panel {
  margin: 0 30rpx 30rpx;
  padding: 24rpx 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.result-panel.correct {
  background: #e7f5e8;
  border: 1rpx solid #2f9e44;
}

.result-panel.wrong {
  background: #fff0f0;
  border: 1rpx solid #ff6b6b;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.result-panel.correct .result-title {
  color: #2f9e44;
}

.result-panel.wrong .result-title {
  color: #e03131;
}

.result-score {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}

.result-detail {
  font-size: 26rpx;
  color: #495057;
  line-height: 1.6;
}

.result-details {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(0,0,0,0.06);
}

.result-detail-item {
  font-size: 24rpx;
  color: #495057;
  line-height: 1.8;
}

/* 题目列表 */
.quiz-list {
  margin: 20rpx 30rpx;
}

.quiz-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.quiz-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.quiz-card-desc {
  font-size: 26rpx;
  color: #6c757d;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.quiz-card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.quiz-card-tag {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  background: #e7ecf8;
  color: #4a69bd;
}

.quiz-card-score {
  font-size: 24rpx;
  color: #4a69bd;
  font-weight: 600;
}
