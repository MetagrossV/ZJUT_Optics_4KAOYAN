/** 绘图题页面样式 **/

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f5f6fa;
}

/* 题目区 */
.quiz-header {
  background: #ffffff;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #e9ecef;
}

.quiz-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}

.quiz-description {
  font-size: 28rpx;
  color: #495057;
  line-height: 1.6;
}

.quiz-progress {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.progress-text {
  font-size: 24rpx;
  color: #6c757d;
}

.score-badge {
  background: #4a69bd;
  color: #ffffff;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* Canvas 区域 */
.canvas-wrapper {
  margin: 20rpx 30rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  position: relative;
}

.drawing-canvas {
  display: block;
  width: 750rpx;
  height: 600rpx;
  background: #f8f9fa;
}

/* 绘图工具栏 */
.toolbar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 16rpx 30rpx;
  background: #ffffff;
  margin: 0 30rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.tool-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  transition: background 0.2s;
}

.tool-btn.active {
  background: #e7ecf8;
}

.tool-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.tool-label {
  font-size: 24rpx;
  color: #495057;
}

.tool-btn.active .tool-label {
  color: #4a69bd;
  font-weight: 600;
}

/* 操作按钮 */
.action-bar {
  display: flex;
  justify-content: space-between;
  padding: 0 30rpx 20rpx;
}

.action-btn {
  flex: 1;
  margin: 0 10rpx;
  padding: 22rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  text-align: center;
  border: none;
}

.btn-primary {
  background: #4a69bd;
  color: #ffffff;
}

.btn-secondary {
  background: #e9ecef;
  color: #495057;
}

.btn-danger {
  background: #ff6b6b;
  color: #ffffff;
}

.btn-success {
  background: #2f9e44;
  color: #ffffff;
}

/* 验证结果 */
.result-panel {
  margin: 0 30rpx 30rpx;
  padding: 24rpx 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.result-panel.correct {
  background: #e7f5e8;
  border: 1rpx solid #2f9e44;
}

.result-panel.wrong {
  background: #fff0f0;
  border: 1rpx solid #ff6b6b;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.result-panel.correct .result-title {
  color: #2f9e44;
}

.result-panel.wrong .result-title {
  color: #e03131;
}

.result-detail {
  font-size: 26rpx;
  color: #495057;
  line-height: 1.6;
}

/* 题目列表 */
.quiz-list {
  margin: 20rpx 30rpx;
}

.quiz-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.quiz-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.quiz-card-desc {
  font-size: 26rpx;
  color: #6c757d;
  margin-bottom: 16rpx;
}

.quiz-card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.quiz-card-tag {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  background: #e7ecf8;
  color: #4a69bd;
}

.quiz-card-score {
  font-size: 24rpx;
  color: #4a69bd;
  font-weight: 600;
}
