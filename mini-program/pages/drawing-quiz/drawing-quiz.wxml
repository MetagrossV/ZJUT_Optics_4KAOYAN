<view class="container">
  <!-- 题目列表视图 -->
  <block wx:if="{{!currentQuiz}}">
    <view class="quiz-header">
      <view class="quiz-title">光学绘图题</view>
      <view class="quiz-description">从工具箱选择光学器件，放置到画布上构建光路图</view>
    </view>
    <view class="quiz-list">
      <block wx:for="{{quizList}}" wx:key="id">
        <view class="quiz-card" bindtap="selectQuiz" data-quiz-id="{{item.id}}">
          <view class="quiz-card-title">{{item.title}}</view>
          <view class="quiz-card-desc">{{item.description}}</view>
          <view class="quiz-card-meta">
            <view class="quiz-card-tag">{{item.sceneName}}</view>
            <view class="quiz-card-score">{{item.scoring.total}}分</view>
          </view>
        </view>
      </block>
    </view>
  </block>

  <!-- 答题视图 -->
  <block wx:if="{{currentQuiz}}">
    <view class="quiz-header">
      <view class="quiz-title">{{currentQuiz.title}}</view>
      <view class="quiz-description">{{currentQuiz.description}}</view>
      <view class="quiz-progress">
        <text class="progress-text">第 {{currentQuizIndex + 1}} / {{quizList.length}} 题</text>
        <text class="score-badge" wx:if="{{quizScore >= 0}}">得分: {{quizScore}}</text>
      </view>
    </view>

    <!-- 画布区域 -->
    <view class="canvas-wrapper">
      <canvas
        type="2d"
        id="drawingCanvas"
        class="drawing-canvas"
        style="width: {{canvasWidth}}rpx; height: {{canvasHeight}}rpx;"
        bindtouchstart="onCanvasTouchStart"
        bindtouchmove="onCanvasTouchMove"
        bindtouchend="onCanvasTouchEnd"
      ></canvas>
      <!-- 放置提示 -->
      <view wx:if="{{isPlacing && selectedToolName}}" class="placement-hint">
        <text>点击画布放置 {{selectedToolName}}</text>
      </view>
    </view>

    <!-- 工具箱 -->
    <view class="toolbox">
      <view class="toolbox-title">工具箱</view>
      <view class="toolbox-items">
        <block wx:for="{{toolbox}}" wx:key="id">
          <view 
            class="toolbox-item {{selectedTool === item.id ? 'active' : ''}}" 
            bindtap="selectTool" 
            data-tool-id="{{item.id}}"
          >
            <view class="toolbox-icon" style="background: {{item.color}};">{{item.icon}}</view>
            <text class="toolbox-name">{{item.name}}</text>
          </view>
        </block>
      </view>
    </view>

    <!-- 参数面板（选中器件时显示） -->
    <view wx:if="{{paramPanelVisible && selectedElementId}}" class="param-panel">
      <view class="param-panel-header">
        <text class="param-panel-title">器件参数</text>
        <text class="param-panel-delete" bindtap="deleteSelectedElement">删除</text>
      </view>
      <block wx:for="{{elements}}" wx:key="id">
        <block wx:if="{{item.id === selectedElementId}}">
          <!-- 凸透镜/凹透镜参数 -->
          <block wx:if="{{item.type === 'convex-lens' || item.type === 'concave-lens'}}">
            <view class="param-row">
              <text class="param-label">焦距 f</text>
              <slider class="param-slider" min="-300" max="300" value="{{item.params.focalLength}}" show-value bindchange="onParamChange" data-param-key="focalLength"/>
            </view>
            <view class="param-row">
              <text class="param-label">孔径</text>
              <slider class="param-slider" min="60" max="200" value="{{item.params.aperture}}" show-value bindchange="onParamChange" data-param-key="aperture"/>
            </view>
          </block>
          <!-- 平面镜参数 -->
          <block wx:if="{{item.type === 'plane-mirror'}}">
            <view class="param-row">
              <text class="param-label">倾斜角</text>
              <slider class="param-slider" min="-90" max="90" value="{{item.params.angle}}" show-value bindchange="onParamChange" data-param-key="angle"/>
            </view>
            <view class="param-row">
              <text class="param-label">长度</text>
              <slider class="param-slider" min="60" max="300" value="{{item.params.length}}" show-value bindchange="onParamChange" data-param-key="length"/>
            </view>
          </block>
          <!-- 物体参数 -->
          <block wx:if="{{item.type === 'object'}}">
            <view class="param-row">
              <text class="param-label">高度</text>
              <slider class="param-slider" min="20" max="150" value="{{item.params.height}}" show-value bindchange="onParamChange" data-param-key="height"/>
            </view>
          </block>
        </block>
      </block>
    </view>

    <!-- 操作按钮 -->
    <view class="action-bar">
      <button class="action-btn btn-secondary" bindtap="addRay">添加光线</button>
      <button class="action-btn btn-secondary" bindtap="addAuxiliaryLines">辅助线</button>
      <button class="action-btn btn-primary" bindtap="submitDrawing">验证</button>
      <button class="action-btn btn-danger" bindtap="clearCanvas">清空</button>
    </view>

    <!-- 验证结果 -->
    <view wx:if="{{validationResult}}" class="result-panel {{validationResult.isCorrect ? 'correct' : 'wrong'}}">
      <view class="result-title">{{validationResult.isCorrect ? '✓ 回答正确' : '✗ 回答有误'}}</view>
      <view class="result-score">得分: {{validationResult.score}} 分</view>
      <view class="result-detail">{{validationResult.message}}</view>
      <view wx:if="{{validationResult.details}}" class="result-details">
        <block wx:for="{{validationResult.details}}" wx:key="index">
          <view class="result-detail-item">{{item}}</view>
        </block>
      </view>
    </view>

    <!-- 底部导航 -->
    <view class="action-bar" wx:if="{{validationResult}}">
      <button class="action-btn btn-success" bindtap="nextQuiz" wx:if="{{currentQuizIndex < quizList.length - 1}}">下一题</button>
      <button class="action-btn btn-secondary" bindtap="backToList">返回列表</button>
      <button class="action-btn btn-danger" bindtap="quitQuiz">退出</button>
    </view>
  </block>
</view>
