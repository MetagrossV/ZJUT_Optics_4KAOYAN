/* pages/card-memory/card-memory.wxss */
.card-mode-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.flip-card-container {
  perspective: 1000rpx;
  margin: 40rpx 0;
}

.flip-card {
  width: 100%;
  height: 500rpx;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.6s;
}

.flip-card.flipped {
  transform: rotateY(180deg);
}

.flip-card-front, .flip-card-back {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 20rpx;
  background: var(--card-bg);
  box-shadow: var(--shadow);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.flip-card-back {
  transform: rotateY(180deg);
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.flip-card-content {
  text-align: center;
  width: 100%;
}

.flip-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: var(--primary);
  color: white;
  margin-bottom: 24rpx;
}

.flip-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text);
  line-height: 1.4;
  margin-bottom: 40rpx;
}

.flip-hint {
  font-size: 24rpx;
  color: var(--text-light);
}

.flip-back-title {
  font-size: 32rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 24rpx;
}

.flip-back-content {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.flip-back-formula {
  background: rgba(255,255,255,0.2);
  border-radius: 12rpx;
  padding: 20rpx;
}

.flip-back-formula .formula-latex {
  color: white;
  font-size: 32rpx;
}

.card-counter {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 20rpx;
}

.card-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-top: 40rpx;
}

.card-actions .btn-outline,
.card-actions .btn-primary {
  min-width: 160rpx;
}

.card-actions .btn-outline.favorited {
  border-color: var(--danger);
  color: var(--danger);
}

/* 填空模式 */
.fill-card {
  padding: 40rpx;
}

.fill-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: var(--primary);
  color: white;
  margin-bottom: 20rpx;
}

.fill-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 24rpx;
}

.fill-question {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: var(--bg);
  border-radius: 12rpx;
}

.fill-blank {
  margin-bottom: 24rpx;
}

.fill-input {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text);
  background: var(--bg);
  box-sizing: border-box;
}

.fill-actions {
  display: flex;
  justify-content: center;
}

.fill-result {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
}

.fill-result.correct {
  background: #e8f5e9;
  color: var(--success);
}

.fill-result.wrong {
  background: #ffebee;
  color: var(--danger);
}

.fill-answer {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--text);
}
