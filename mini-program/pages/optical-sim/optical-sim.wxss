/** 光学模拟页面样式 **/

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f5f6fa;
}

/* 头部场景选择器 */
.header {
  background: #ffffff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #e9ecef;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.scene-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.scene-label {
  font-size: 28rpx;
  color: #6c757d;
}

.scene-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  flex: 1;
  text-align: center;
}

.arrow {
  font-size: 24rpx;
  color: #4a69bd;
}

/* Canvas 区域 */
.canvas-wrapper {
  margin: 20rpx 30rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  display: flex;
  justify-content: center;
  align-items: center;
}

.optical-canvas {
  display: block;
  width: 100%;
  height: 600rpx;
}

.drag-hint {
  position: absolute;
  bottom: 10rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 22rpx;
  color: #6c757d;
  background: rgba(255, 255, 255, 0.9);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  pointer-events: none;
}

/* 控制区 */
.controls {
  margin: 0 30rpx 20rpx;
  padding: 24rpx 30rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.controls-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #e9ecef;
}

.param-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.param-name {
  font-size: 28rpx;
  color: #495057;
}

.param-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #4a69bd;
  min-width: 80rpx;
  text-align: right;
}

.param-slider {
  margin-bottom: 20rpx;
}

/* 图例 */
.legend {
  margin: 0 30rpx 30rpx;
  padding: 24rpx 30rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.legend-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #495057;
}

.legend-color {
  width: 32rpx;
  height: 6rpx;
  border-radius: 3rpx;
  margin-right: 16rpx;
}
